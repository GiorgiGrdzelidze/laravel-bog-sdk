{
    "name": "giorgigrdzelidze/laravel-bog-sdk",
    "description": "Laravel SDK for Bank of Georgia APIs: Business Online, Payments, iPay, Installment, BOG-ID, and Open Banking.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "bog",
        "bank-of-georgia",
        "sdk",
        "laravel",
        "payments",
        "bonline",
        "ipay",
        "installment"
    ],
    "homepage": "https://github.com/GiorgiGrdzelidze/laravel-bog-sdk",
    "support": {
        "issues": "https://github.com/GiorgiGrdzelidze/laravel-bog-sdk/issues",
        "source": "https://github.com/GiorgiGrdzelidze/laravel-bog-sdk"
    },
    "authors": [
        {
            "name": "Giorgi Grdzelidze",
            "homepage": "https://github.com/GiorgiGrdzelidze",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/cache": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "GiorgiGrdzelidze\\BogSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GiorgiGrdzelidze\\BogSdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GiorgiGrdzelidze\\BogSdk\\BogSdkServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "pint": "pint",
        "ci": [
            "@test",
            "@phpstan",
            "@pint -- --test"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
